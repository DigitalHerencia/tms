// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

enum UserRole {
  admin
  dispatcher
  driver
  compliance
  user
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum LoadStatus {
  draft
  pending
  posted
  booked
  confirmed
  assigned
  dispatched
  in_transit
  at_pickup
  picked_up
  en_route
  at_delivery
  delivered
  pod_required
  completed
  invoiced
  paid
  cancelled
  problem
}

enum LoadPriority {
  low
  medium
  high
  urgent
}

enum VehicleStatus {
  active
  inactive
  maintenance
  out_of_service
}

enum VehicleType {
  truck
  trailer
  van
  pickup
  other
}

enum DriverStatus {
  available
  assigned
  driving
  off_duty
  on_break
  inactive
}

model User {
  id                 String    @id @default(uuid())
  clerkId            String    @unique
  organizationId     String?
  email              String?
  firstName          String?
  lastName           String?
  profileImage       String?
  role               UserRole  @default(user)
  permissions        Json?     @default("[]")
  isActive           Boolean   @default(true)
  lastLogin          DateTime?
  onboardingComplete Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  organization           Organization?            @relation("OrganizationUsers", fields: [organizationId], references: [id], onDelete: SetNull)
  organizationMembership OrganizationMembership[]
  sentInvitations        Invitation[]             @relation("InvitationSender")
  receivedInvitations    Invitation[]             @relation("InvitationReceiver")
  auditLogs              AuditLog[]
  driver                 Driver?

  @@map("users")
}

model Organization {
  id                 String   @id @default(uuid())
  clerkId            String?  @unique
  name               String
  slug               String   @unique
  dotNumber          String?
  mcNumber           String?
  address            String?
  city               String?
  state              String?
  zip                String?
  phone              String?
  subscriptionTier   String   @default("free")
  subscriptionStatus String   @default("trial")
  maxUsers           Int      @default(5)
  features           Json?    @default("[]")
  billingEmail       String?
  settings           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  users               User[]                   @relation("OrganizationUsers")
  memberships         OrganizationMembership[]
  invitations         Invitation[]
  auditLogs           AuditLog[]
  drivers             Driver[]
  customers           Customer[]
  trailers            Trailer[]
  vehicles            Vehicle[]
  loads               Load[]
  iftaQuarters        IftaQuarter[]
  iftaTrips           IftaTrip[]
  iftaFuelPurchases   IftaFuelPurchase[]
  complianceDocuments ComplianceDocument[]
  subscription        Subscription?

  @@map("organizations")
}

model OrganizationMembership {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           UserRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_memberships")
}

model Invitation {
  id                String           @id @default(uuid())
  organizationId    String
  inviterUserId     String
  inviteeUserId     String? // Set when invitation is accepted
  email             String
  role              UserRole
  status            InvitationStatus @default(pending)
  token             String           @unique
  clerkInvitationId String?          @unique // Clerk's invitation ID for sync
  redirectUrl       String?
  bypassOnboarding  Boolean          @default(false)
  metadata          Json?            @default("{}")
  expiresAt         DateTime
  acceptedAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("InvitationSender", fields: [inviterUserId], references: [id])
  invitee      User?        @relation("InvitationReceiver", fields: [inviteeUserId], references: [id])

  @@map("invitations")
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime @default(now())

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("audit_logs")
}

model Driver {
  id                   String       @id @default(uuid())
  organizationId       String
  userId               String?      @unique // Optional link to User model
  employeeId           String?
  firstName            String
  lastName             String
  email                String?
  phone                String?
  licenseNumber        String?
  licenseState         String?
  licenseExpiration    DateTime?
  cdlClass             String?
  cdlExpiration        DateTime?
  dotMedicalExpiration DateTime?
  hazmatExpiration     DateTime?
  status               DriverStatus @default(available)
  address              String?
  city                 String?
  state                String?
  zip                  String?
  emergencyContact     String?
  emergencyPhone       String?
  dateOfBirth          DateTime?
  hireDate             DateTime?
  terminationDate      DateTime?
  notes                String?
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  vehicles     Vehicle[]
  loads        Load[]       @relation("LoadDriver")
  iftaTrips    IftaTrip[]   @relation("IftaDriverTrips")

  @@unique([organizationId, employeeId])
  @@map("drivers")
}

model Customer {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  billingAddress String?
  paymentTerms   String?
  creditLimit    Float?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  loads        Load[]

  @@map("customers")
}

model Trailer {
  id                 String        @id @default(uuid())
  organizationId     String
  unitNumber         String
  type               String
  make               String?
  model              String?
  year               Int?
  vin                String?       @unique
  licensePlate       String?
  status             VehicleStatus @default(active)
  lastInspectionDate DateTime?
  nextInspectionDue  DateTime?
  capacity           Float?
  notes              String?
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  loads        Load[]       @relation("LoadTrailer")

  @@unique([organizationId, unitNumber])
  @@map("trailers")
}

model Vehicle {
  id                 String        @id @default(uuid())
  organizationId     String
  unitNumber         String
  vin                String        @unique
  make               String?
  model              String?
  year               Int?
  licensePlate       String?
  type               VehicleType   @default(truck)
  status             VehicleStatus @default(active)
  currentOdometer    Int?
  lastInspectionDate DateTime?
  nextInspectionDue  DateTime?
  fuelType           String?
  maxWeight          Float?
  notes              String?
  driverId           String? // Current assigned driver
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  driver            Driver?            @relation(fields: [driverId], references: [id], onDelete: SetNull)
  loads             Load[]             @relation("LoadVehicle")
  iftaTrips         IftaTrip[]         @relation("IftaVehicleTrips")
  iftaFuelPurchases IftaFuelPurchase[] @relation("IftaVehicleFuelPurchases")

  @@unique([organizationId, unitNumber])
  @@map("vehicles")
}

model Load {
  id              String       @id @default(uuid())
  organizationId  String
  referenceNumber String       @unique
  status          LoadStatus   @default(pending)
  priority        LoadPriority @default(medium)
  customerId      String
  driverId        String?
  vehicleId       String?
  trailerId       String?

  // Origin and Destination
  origin      String
  destination String

  // Dates and Times
  pickupDate            DateTime
  deliveryDate          DateTime
  estimatedPickupTime   String?
  estimatedDeliveryTime String?
  actualPickupTime      DateTime?
  actualDeliveryTime    DateTime?
  scheduledPickupDate   DateTime?
  scheduledDeliveryDate DateTime?

  // Cargo and Equipment
  cargoDescription String?
  cargoWeight      Float?
  cargoValue       Float?
  equipmentType    String?
  equipmentLength  Float?
  temperatureMin   Float?
  temperatureMax   Float?
  hazmat           Boolean @default(false)

  // Financial
  rateAmount         Float?
  ratePer            String?
  fuelSurcharge      Float?
  accessorialCharges Float?
  totalAmount        Float?

  // Tracking
  miles          Float?
  estimatedMiles Float?
  fuelCost       Float?

  // Notes
  notes               String?
  internalNotes       String?
  specialInstructions String?

  // Metadata
  tags            String[]
  brokerName      String?
  brokerContact   String?
  brokerEmail     String?
  brokerPhone     String?
  loadboardSource String?

  // Audit
  createdBy      String?
  lastModifiedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id])
  driver       Driver?           @relation("LoadDriver", fields: [driverId], references: [id], onDelete: SetNull)
  vehicle      Vehicle?          @relation("LoadVehicle", fields: [vehicleId], references: [id], onDelete: SetNull)
  trailer      Trailer?          @relation("LoadTrailer", fields: [trailerId], references: [id], onDelete: SetNull)
  statusEvents LoadStatusEvent[]
  documents    LoadDocument[]

  @@map("loads")
}

model LoadStatusEvent {
  id              String     @id @default(uuid())
  loadId          String
  status          LoadStatus
  timestamp       DateTime   @default(now())
  location        String?
  notes           String?
  automaticUpdate Boolean    @default(false)
  source          String? // 'system', 'driver', 'dispatcher', 'customer', 'eld'
  createdBy       String?
  createdAt       DateTime   @default(now())

  // Relations
  load Load @relation(fields: [loadId], references: [id], onDelete: Cascade)

  @@map("load_status_events")
}

model LoadDocument {
  id         String   @id @default(uuid())
  loadId     String
  name       String
  type       String // 'bill_of_lading', 'pod', 'invoice', 'receipt', 'other'
  url        String?
  filePath   String?
  fileSize   Int?
  mimeType   String?
  uploadedBy String?
  uploadedAt DateTime @default(now())
  isRequired Boolean  @default(false)
  isReceived Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  load Load @relation(fields: [loadId], references: [id], onDelete: Cascade)

  @@map("load_documents")
}

model Subscription {
  id                   String   @id @default(uuid())
  organizationId       String   @unique
  plan                 String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  stripeSubscriptionId String?  @unique
  stripeCustomerId     String?
  maxUsers             Int      @default(5)
  maxVehicles          Int      @default(10)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model WebhookEvent {
  id          String    @id @default(uuid())
  eventId     String    @unique
  eventType   String
  status      String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("webhook_events")
}

// IFTA (International Fuel Tax Agreement) Models
model IftaQuarter {
  id             String    @id @default(uuid())
  organizationId String
  year           Int
  quarter        Int // 1, 2, 3, or 4
  startDate      DateTime
  endDate        DateTime
  isFinalized    Boolean   @default(false)
  filedAt        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trips         IftaTrip[]
  fuelPurchases IftaFuelPurchase[]

  @@unique([organizationId, year, quarter])
  @@map("ifta_quarters")
}

model IftaTrip {
  id                String   @id @default(uuid())
  organizationId    String
  quarterId         String
  vehicleId         String
  driverId          String?
  startDate         DateTime
  endDate           DateTime
  startOdometer     Int
  endOdometer       Int
  totalMiles        Int
  jurisdiction      String // State/Province code
  jurisdictionMiles Int
  fuelGallons       Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quarter      IftaQuarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation("IftaVehicleTrips", fields: [vehicleId], references: [id])
  driver       Driver?      @relation("IftaDriverTrips", fields: [driverId], references: [id])

  @@map("ifta_trips")
}

model IftaFuelPurchase {
  id             String   @id @default(uuid())
  organizationId String
  quarterId      String
  vehicleId      String
  purchaseDate   DateTime
  vendorName     String
  location       String
  jurisdiction   String // State/Province code
  gallons        Float
  pricePerGallon Float
  totalAmount    Float
  receiptNumber  String?
  odometer       Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quarter      IftaQuarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation("IftaVehicleFuelPurchases", fields: [vehicleId], references: [id])

  @@map("ifta_fuel_purchases")
}

// Compliance Models
model ComplianceDocument {
  id             String    @id @default(uuid())
  organizationId String
  entityType     String // 'driver', 'vehicle', 'trailer', 'company'
  entityId       String // ID of the related entity
  type           String // 'license', 'medical', 'inspection', 'insurance', etc.
  name           String
  documentNumber String?
  issueDate      DateTime?
  expirationDate DateTime?
  status         String    @default("valid") // 'valid', 'expiring', 'expired', 'pending', 'rejected'
  filePath       String?
  url            String?
  notes          String?
  tags           String[]
  isRequired     Boolean   @default(false)
  reminderDays   Int? // Days before expiration to send reminder
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("compliance_documents")
}
